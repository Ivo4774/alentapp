// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
    provider = "prisma-client-js"
    output   = "../src/generated/client"
}

datasource db {
    provider = "postgresql"
}

enum MemberCategory {
    Pleno
    Cadete
    Honorario
}

enum MemberStatus {
    Activo
    Moroso
    Suspendido
}

enum LockerStatus {
    Available
    Occupied
    Maintenance
}

model Member {
    id         String         @id @default(uuid())
    dni        String         @unique
    name       String
    email      String         @unique
    birthdate  DateTime?      @db.Date
    category   MemberCategory
    status     MemberStatus   @default(Activo)
    created_at DateTime       @default(now())
    lockers    Locker[]
    payments   Payment[]
    medical_certificates MedicalCertificate[]

    @@map("members") // Para que en la DB la tabla se llame 'members' en minúscula
}

model Locker {
    id         String       @id @default(uuid())
    number     Int          @unique
    location   String
    status     LockerStatus @default(Available)
    member_id  String?
    member     Member?      @relation(fields: [member_id], references: [id])
    created_at DateTime     @default(now())
    updated_at DateTime     @updatedAt

    @@map("lockers")
}

model Payment {
    id           String    @id @default(uuid())
    amount       Float
    month        Int
    year         Int
    status       String    @default("Pending")
    due_date     DateTime
    payment_date DateTime?
    member_id    String
    created_at   DateTime       @default(now())

    member       Member    @relation(fields: [member_id], references: [id])

  @@map("payments")
}

model MedicalCertificate {
    id             String   @id @default(uuid())
    issue_date     DateTime @db.Date
    expiry_date    DateTime @db.Date
    doctor_license String
    is_validated   Boolean  @default(true)
    member_id      String
    member         Member   @relation(fields: [member_id], references: [id])
    file_data      String?
    created_at      DateTime @default(now())
    @@map("medical_certificates")
}
